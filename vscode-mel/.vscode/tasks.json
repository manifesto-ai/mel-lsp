{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:server",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}/.."
      }
    },
    {
      "label": "build:extension",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "build:debug",
      "dependsOn": [
        "build:server",
        "build:extension"
      ],
      "dependsOrder": "sequence"
    }
  ]
}
